{
  "name": "@openclaw/observatory-plugin",
  "version": "1.0.0",
  "description": "Observatory pairing plugin for OpenClaw — registers `openclaw observatory connect`.",
  "main": "dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^20.12.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "observatory",
    "visualization"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  }
}
